{
	"name": "im.debug",
	"version": "0.0.0",
	"description": "import.meta.debug — zero-config debug() calls with file, line, and column auto-baked in",
	"keywords": [
		"debug",
		"import.meta",
		"logger",
		"esm",
		"cjs",
		"commonjs",
		"loader",
		"bun"
	],
	"license": "MIT",
	"repository": "leonsilicon/im.debug",
	"author": {
		"name": "Leon Si",
		"email": "leon@leonsilicon.com"
	},
	"files": [
		"dist",
		"src/types"
	],
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		"./cjs": {
			"types": "./dist/cjs/index.d.cts",
			"default": "./dist/cjs/index.cjs"
		},
		"./node": {
			"types": "./dist/node/index.d.mts",
			"default": "./dist/node/index.mjs"
		},
		"./bun": {
			"types": "./dist/bun/index.d.mts",
			"default": "./dist/bun/index.mjs"
		},
		"./types": "./src/types/index.d.ts",
		"./runtime": {
			"import": {
				"types": "./dist/runtime/index.d.mts",
				"default": "./dist/runtime/index.mjs"
			},
			"require": {
				"types": "./dist/runtime/index.d.cts",
				"default": "./dist/runtime/index.cjs"
			}
		}
	},
	"packageManager": "pnpm@10.9.0",
	"scripts": {
		"build": "pkgroll --minify",
		"lint": "lintroll --node --cache .",
		"type-check": "tsc",
		"prepack": "pnpm build && clean-pkg-json"
	},
	"engines": {
		"node": ">=18.19.0"
	},
	"dependencies": {
		"@types/debug": "^4.1.12"
	},
	"devDependencies": {
		"@types/node": "^22.15.29",
		"clean-pkg-json": "^1.2.0",
		"lintroll": "^1.8.1",
		"pkgroll": "^2.4.1",
		"typescript": "^5.5.2"
	}
}
